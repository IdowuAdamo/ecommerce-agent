# ── Required ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
HF_TOKEN=your_huggingface_token_here
SUPABASE_URL=https://your-project-ref.supabase.co
PINECONE_API_KEY=your_pinecone_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Price model HuggingFace repo (default: Idowenst/ecommerce-price-predictor-v1)
PRICE_MODEL_ID=Idowenst/ecommerce-price-predictor-v1

# Device: "cpu" (default) or "cuda" if GPU available
PRICE_MODEL_DEVICE=cpu

# Pinecone index name (created automatically)
PINECONE_INDEX_NAME=naijashop-products

# OpenAI model (gpt-4o-mini is cost-efficient, gpt-4o for best quality)
OPENAI_MODEL=gpt-4o-mini

# Database override (if not using Supabase)
# DATABASE_URL=postgresql://user:password@localhost:5432/naijashop

# Redis (optional — uses in-memory fallback)
# REDIS_URL=redis://localhost:6379

# Scraper settings
SCRAPER_DELAY_SECONDS=2.0
SCRAPER_MAX_RETRIES=3

# Recommendation weights (must sum to 1.0)
REC_SEMANTIC_WEIGHT=0.25
REC_BEHAVIORAL_WEIGHT=0.20
REC_PRICE_FAIRNESS_WEIGHT=0.25
REC_TRUST_WEIGHT=0.20
REC_CONTEXTUAL_WEIGHT=0.10

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
